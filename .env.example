NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
# 留空表示前端与 API 走同域，由 nginx 反代 /api 和 /uploads 到后端服务。
# 如果前端和 API 分开部署，必须在 pnpm run build 之前写成完整地址，例如 https://api.example.com
VITE_API_BASE_URL=
API_PORT=4000
# 推荐把本地内容、管理员配置、聊天记录、上传素材放到代码目录外，例如 /opt/yakewangye-local
# 也可以在仓库根目录创建 local/project-paths.json 并写入 {"dataRoot":"/your/path"}
YK_DATA_DIR=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
ADMIN_TOKEN_SECRET=replace_me_in_production
POSTGRES_DB=quanyu
POSTGRES_USER=quanyu
POSTGRES_PASSWORD=quanyu_dev
REDIS_PORT=6379
METABASE_PORT=3001
